<%
  const s = typeof site !== "undefined" && site ? site : {};
  const siteName = String(s.name || "Spraying Mantis Auto Repairs").trim();
  const siteDomain = String(s.domain || "").replace(/\/$/, "");

  const hasTitle = typeof title !== "undefined" && title;
  const hasMetaTitle = typeof metaTitle !== "undefined" && metaTitle;
  const hasMetaDescription = typeof metaDescription !== "undefined" && metaDescription;
  const hasOgTitle = typeof ogTitle !== "undefined" && ogTitle;
  const hasOgDescription = typeof ogDescription !== "undefined" && ogDescription;
  const hasCanonicalPath = typeof canonicalPath !== "undefined" && canonicalPath;
  const hasCanonicalUrl = typeof canonicalUrl !== "undefined" && canonicalUrl;
  const hasOgImage = typeof ogImage !== "undefined" && ogImage;

  const resolvedTitle = hasMetaTitle || hasTitle || siteName;
  const resolvedDescription =
    hasMetaDescription ||
    `Vehicle body repairs, paintwork and accident repair services from ${siteName}.`;

  const resolvedOgTitle = hasOgTitle || resolvedTitle;
  const resolvedOgDescription = hasOgDescription || resolvedDescription;

  const resolvedCanonicalPath = hasCanonicalPath || "";
  const resolvedCanonicalUrl =
    hasCanonicalUrl || (siteDomain ? `${siteDomain}${resolvedCanonicalPath}` : "");

  const resolvedOgImage =
    hasOgImage ||
    (siteDomain
      ? `${siteDomain}${s.logo || "/mantis-logo.png"}`
      : (s.logo || "/mantis-logo.png"));
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= resolvedTitle %></title>
  <meta name="description" content="<%= resolvedDescription %>" />

  <% if (resolvedCanonicalUrl) { %>
    <link rel="canonical" href="<%= resolvedCanonicalUrl %>" />
    <meta property="og:url" content="<%= resolvedCanonicalUrl %>" />
  <% } %>

  <meta property="og:title" content="<%= resolvedOgTitle %>" />
  <meta property="og:description" content="<%= resolvedOgDescription %>" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="<%= resolvedOgImage %>" />

  <link rel="icon" type="image/png" href="/mantis-logo.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
